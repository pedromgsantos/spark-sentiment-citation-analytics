# Copy this file to .env and fill with your real values
# cp .env.example .env

# Tailscale auth key (from admin console)
TS_AUTHKEY=tskey-auth-REPLACE_ME

# MongoDB credentials used by docker-compose and producer
MONGO_USER=admin
MONGO_PASS=change_me

# IMPORTANT: Put your machine's Tailscale IP here
TS_IP_ADDRESS=100.100.100.100

# YouTube source
YOUTUBE_VIDEO_ID=REPLACE_VIDEO_ID
YOUTUBE_API_KEY=REPLACE_YOUTUBE_API_KEY

# Kafka producer settings
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=youtube_comments
POLL_INTERVAL_SECONDS=30
KAFKA_STARTUP_TIMEOUT_SECONDS=120

# Mongo checkpoint settings
MONGO_DB_NAME=youtube_stream
MONGO_COLLECTION_NAME=producer_state
MONGO_STARTUP_TIMEOUT_SECONDS=120
